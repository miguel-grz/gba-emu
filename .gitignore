/target

# Node / frontend build
node_modules/
dist/
web/pkg/

# macOS
.DS_Store

# Generated render dumps
*.bmp
*.ppm
*.png
# ...except the Tauri app icons, which must be committed for bundling.
!src-tauri/icons/*.png
# ...and the README screenshots.
!docs/screenshots/*.png

# Test ROMs are fetched locally, never committed
core/tests/roms/
*.gba
*.sav

# BIOS dumps must never be committed
*.bin
bios*.rom

# Local Claude Code config
.claude/
